# crm/locale/main.pot is a generated translations template (regenerated by
# `bench generate-pot-file --app crm` and the generate-pot-file.yml workflow).
# It routinely conflicts on main <-> main-hotfix merges purely on its
# POT-Creation-Date header. Resolve such conflicts by keeping the current
# branch's copy instead of halting the merge; CI regenerates the canonical file.
#
# NOTE: the "ours" driver must be registered once per clone / CI environment:
#   git config merge.ours.driver true
crm/locale/main.pot merge=ours
